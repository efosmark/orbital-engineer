#ifndef NUDGE_CLH_
#define NUDGE_CLH_

#include "kernel/complex.clh"

inline void nudge(
    const int i,
    const int j,
    const cfloat dr_norm,
    const float overlap,
    const float inv_mass_i,
    const float inv_mass_j,
    cfloat *position
) {
    float k = overlap / (inv_mass_i + inv_mass_j);
    position[i] -= dr_norm * (k * inv_mass_i);
    position[j] += dr_norm * (k * inv_mass_j);
}

#endif // NUDGE_CLH_