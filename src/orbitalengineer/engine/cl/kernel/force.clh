#ifndef FORCE_CLH_
#define FORCE_CLH_

#include "kernel/complex.clh"

#ifndef G
#define G 1.0
#endif

inline cfloat force(
    const int i,
    const int j,
    const cfloat dr,
    const float dist,
    const float *mass
) {
    return (((float)(G) * mass[i] * mass[j]) / (dist*dist*dist)) * dr;
}

#endif // FORCE_CLH_